# FastAPI
VITE_API_BASE=http://localhost:8000

# Supabase browser client (the anon key is safe to expose; never use the service-role key here)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_RECAP_LEAGUE_SLUG=patriot-games
VITE_RECAP_SEASON=2026
# FastAPI base URL (no trailing slash).
# Dev: use /api so Vite proxies to http://127.0.0.1:8000 (avoids CORS). Or set http://localhost:8000 if you prefer direct calls.
VITE_API_BASE=/api

# Base URL used only for recap generation (bypasses the Vite dev proxy, which
# drops long-running requests -- ESPN assembly + an LLM call, 10-15s -- even
# with an extended proxy timeout). Backend CORS already allows localhost/
# 127.0.0.1 origins. Defaults to http://127.0.0.1:8000 in dev if unset.
VITE_API_BASE_DIRECT=http://127.0.0.1:8000
