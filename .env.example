# Copy to .env and fill in. Never commit .env.

# Anthropic (AI recaps / matchup commentary)
ANTHROPIC_API_KEY=

# Phase 1 structured recap generation
RECAP_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Supabase (recap persistence and Patrick admin auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RECAP_LEAGUE_SLUG=patriot-games
PUBLIC_APP_URL=http://localhost:5173

# ESPN fantasy league (see docs/ESPN_ACCESS_HANDOFF.md for how to get the cookies)
ESPN_LEAGUE_ID=3853870
ESPN_SEASON=2026
ESPN_SWID=
ESPN_S2=

# Draft optimizer league year (may differ from ESPN_SEASON)
DRAFT_LEAGUE_YEAR=2025
